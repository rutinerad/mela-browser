doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title
      block title
        | Mela Recipes
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin="")
    link(rel="stylesheet", href="https://fonts.googleapis.com/css2?family=Lora:wght@600&display=swap")
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.20.1/cdn/themes/light.css")
    link(rel="stylesheet", media="(prefers-color-scheme:dark)", href="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.20.1/cdn/themes/dark.css", onload="document.documentElement.classList.add('sl-theme-dark');")
    script(type="module", src="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.20.1/cdn/shoelace-autoloader.js")
    script(src="https://cdn.jsdelivr.net/npm/marked/marked.min.js")
    style.
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        font-size: var(--sl-font-size-medium);
        color: var(--sl-color-neutral-700);
        background: var(--sl-color-neutral-0);
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1.5rem;

        a { color: inherit; text-decoration: none; }

        .recipe-title { font-family: 'Lora', serif; }

        .meta {
          color: var(--sl-color-neutral-500);
          font-size: var(--sl-font-size-small);
          font-weight: var(--sl-font-weight-semibold);

          sl-icon { vertical-align: middle; }
        }

        .markdown {
          font-size: var(--sl-font-size-small);
          line-height: 1.6;

          li { margin-bottom: var(--sl-spacing-x-small); }
          &[data-style="ul"] li { margin-bottom: var(--sl-spacing-2x-small); }

          h1, h2, h3 {
            font-size: var(--sl-font-size-medium);
            font-weight: var(--sl-font-weight-semibold);
            margin: var(--sl-spacing-medium) 0 var(--sl-spacing-x-small);
            border: none;
          }
        }
      }
  body
    block content
