doctype html
html(lang="en")
  head
    meta(charset="utf-8")
    meta(name="viewport", content="width=device-width, initial-scale=1")
    title
      block title
        | Mela Recipes
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.20.1/cdn/themes/light.css")
    link(rel="stylesheet", media="(prefers-color-scheme:dark)", href="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.20.1/cdn/themes/dark.css", onload="document.documentElement.classList.add('sl-theme-dark');")
    script(type="module", src="https://cdn.jsdelivr.net/npm/@shoelace-style/shoelace@2.20.1/cdn/shoelace-autoloader.js")
    style.
      body {
        font-family: var(--sl-font-sans);
        font-size: var(--sl-font-size-medium);
        color: var(--sl-color-neutral-900);
        background: var(--sl-color-neutral-0);
        max-width: 900px;
        margin: 0 auto;
        padding: 2rem 1.5rem;
      }
      h1, h2, h3 {
        font-weight: var(--sl-font-weight-semibold);
        line-height: var(--sl-line-height-dense);
      }
      a { color: inherit; text-decoration: none; }
      pre {
        font-family: var(--sl-font-mono);
        font-size: var(--sl-font-size-small);
        white-space: pre-wrap;
        line-height: var(--sl-line-height-normal);
      }
  body
    block content
