extends base.pug

block content
  style.
    ul { list-style: none; padding: 0; margin: 0; }
    li {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: var(--sl-spacing-small) 0;
      border-bottom: 1px solid var(--sl-color-neutral-100);
      gap: var(--sl-spacing-medium);
    }
    .tags { display: flex; gap: var(--sl-spacing-2x-small); flex-shrink: 0; }
  sl-breadcrumb
    sl-breadcrumb-item Recipes
  h1 Recipes (#{recipes|length})
  sl-input#filter(placeholder="Filter recipes...", clearable, autofocus, style="margin: var(--sl-spacing-large) 0")
  ul#list
    each r in recipes
      li(data-title='#{r.title|lower}')
        a(href='/recipe/#{r.pk}') #{r.title}
        if r.tags
          .tags
            each tag in r.tags
              sl-tag(variant="neutral", size="small") #{tag}
  script.
    const filter = document.getElementById('filter');
    const items = document.querySelectorAll('#list li');
    filter.addEventListener('sl-input', () => {
      const q = filter.value.toLowerCase();
      items.forEach(li => li.style.display = li.dataset.title.includes(q) ? '' : 'none');
    });
