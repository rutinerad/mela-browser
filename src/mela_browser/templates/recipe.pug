extends base.pug

block title
  | #{recipe.title}

block content
  div(style="display:flex; justify-content:space-between; align-items:center")
    sl-breadcrumb
      sl-breadcrumb-item(href='/') Recipes
      sl-breadcrumb-item #{recipe.title}
    sl-button(href='/recipe/#{recipe.pk}/melarecipe', variant="text", size="small")
      sl-icon(name="download", style="font-size:1.2rem; font-weight:bold")
  if recipe.images
    img(src='/recipe/#{recipe.pk}/image/#{recipe.images[0].index}', alt='#{recipe.title}', style='width:100%;max-height:400px;object-fit:cover;border-radius:var(--sl-border-radius-large);margin:var(--sl-spacing-medium) 0')
  h1.recipe-title #{recipe.title}
  if recipe.tags
    div.tags(style="margin-bottom: var(--sl-spacing-large)")
      each tag in recipe.tags
        sl-tag(variant="neutral") #{tag}
  if meta or yield_value or source_label
    p.meta
      | #{meta}
      if yield_value
        if meta
          |  ·
        sl-icon(name="person")
        |  #{yield_value}
      if source_label
        |  ·
        if source_url
          a(href='#{source_url}', target='_blank')
            sl-icon(name="book")
            |  #{source_label}
        else
          sl-icon(name="book")
          |  #{source_label}
  if recipe.ingredients
    h2 Ingredients
    div.markdown(data-style="ul") #{recipe.ingredients}
  if recipe.instructions
    h2 Instructions
    div.markdown(data-style="ol") #{recipe.instructions}
  if recipe.notes
    sl-details(summary="Notes", open)
      div.markdown #{recipe.notes}
  script.
    function addListMarkers(text, prefix) {
      return text.split('\n').map(line => {
        if (!line.trim() || line.startsWith('#')) return line;
        return prefix + line;
      }).join('\n');
    }
    document.querySelectorAll('.markdown').forEach(el => {
      let text = el.textContent.trim();
      if (el.dataset.style === 'ul') text = addListMarkers(text, '- ');
      if (el.dataset.style === 'ol') text = addListMarkers(text, '1. ');
      el.innerHTML = DOMPurify.sanitize(marked.parse(text));
    });
