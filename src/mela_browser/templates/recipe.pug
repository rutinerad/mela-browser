extends base.pug

block title
  | #{recipe.title}

block content
  sl-button(href='/', variant="text") ← All recipes
  h1 #{recipe.title}
  if recipe.tags
    div
      each tag in recipe.tags
        sl-badge(variant="neutral") #{tag}
  sl-divider
  if recipe.prep_time or recipe.cook_time or recipe.total_time or recipe.yield_value
    each label, val in [("Prep", recipe.prep_time), ("Cook", recipe.cook_time), ("Total", recipe.total_time), ("Yield", recipe.yield_value)]
      if val
        sl-badge(variant="primary") #{label}: #{val}
    sl-divider
  if recipe.ingredients
    sl-details(summary="Ingredients", open)
      pre #{recipe.ingredients}
  if recipe.instructions
    sl-details(summary="Instructions", open)
      pre #{recipe.instructions}
  if recipe.notes
    sl-details(summary="Notes", open)
      pre #{recipe.notes}
  if recipe.link
    sl-button(href='#{recipe.link}', target='_blank') Source ↗
